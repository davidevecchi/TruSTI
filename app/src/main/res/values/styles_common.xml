<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Common component styles for Material Design 3 consistency -->
    
    <!-- Card styles -->
    <style name="Widget.TruSTI.Card.Elevated" parent="">
        <item name="cardCornerRadius">@dimen/m3_shape_corner_large</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>
    
    <style name="Widget.TruSTI.Card.Filled" parent="">
        <item name="cardCornerRadius">@dimen/m3_shape_corner_large</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
    </style>
    
    <!-- Button styles -->
    <style name="Widget.TruSTI.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/m3_shape_corner_small</item>
        <item name="android:textAppearance">@style/TextAppearance.TruSTI.Button</item>
    </style>
    
    <style name="Widget.TruSTI.Button.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/m3_shape_corner_small</item>
        <item name="android:textAppearance">@style/TextAppearance.TruSTI.LabelLarge</item>
    </style>
    
    <!-- FAB styles -->
    <style name="Widget.TruSTI.ExtendedFloatingActionButton" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="android:textAppearance">@style/TextAppearance.TruSTI.ExtendedFloatingActionButton</item>
    </style>
    
    <!-- Text input styles -->
    <style name="Widget.TruSTI.TextInputLayout.OutlinedBox" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/m3_shape_corner_small</item>
        <item name="boxCornerRadiusTopEnd">@dimen/m3_shape_corner_small</item>
        <item name="boxCornerRadiusBottomStart">@dimen/m3_shape_corner_small</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/m3_shape_corner_small</item>
    </style>
    
    <!-- Chip styles -->
    <style name="Widget.TruSTI.Chip.Suggestion" parent="">
        <item name="chipCornerRadius">@dimen/m3_shape_corner_small</item>
        <item name="android:textAppearance">@style/TextAppearance.TruSTI.LabelMedium</item>
    </style>
    
    <!-- Message bubble styles -->
    <style name="Widget.TruSTI.MessageBubble.Incoming" parent="">
        <item name="cardCornerRadius">@dimen/m3_shape_corner_medium</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
    </style>
    
    <style name="Widget.TruSTI.MessageBubble.Outgoing" parent="">
        <item name="cardCornerRadius">@dimen/m3_shape_corner_medium</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?attr/colorPrimaryContainer</item>
    </style>
    
    <!-- Bottom navigation styles -->
    <style name="Widget.TruSTI.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>
