<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="0dp"
            android:src="@drawable/ic_logo"
            android:contentDescription="@string/app_name" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="40dp"
            android:text="@string/app_name"
            android:textAppearance="@style/TextAppearance.TruSTI.DisplaySmall"
            android:letterSpacing="0.08" />

        <!-- QR code card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.TruSTI.Card.Elevated">

            <ImageView
                android:id="@+id/imgQr"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:contentDescription="@string/qr_content_desc"
                android:padding="12dp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:text="@string/qr_hint"
            android:textAppearance="@style/TextAppearance.TruSTI.BodySmall"
            android:gravity="center"
            android:alpha="0.55" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScan"
            android:layout_width="260dp"
            android:layout_height="56dp"
            android:text="@string/btn_scan_peer"
            style="@style/Widget.TruSTI.Button"
            app:icon="@drawable/ic_qr"
            app:iconSize="24dp"
            app:iconPadding="10dp"
            app:iconGravity="textStart" />

    </LinearLayout>
</ScrollView>
