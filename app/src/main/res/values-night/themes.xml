<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.TruSTI" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/md_primary_dark</item>
        <item name="colorOnPrimary">@color/md_on_primary_dark</item>
        <item name="colorPrimaryContainer">@color/md_primary_container_dark</item>
        <item name="colorOnPrimaryContainer">@color/md_on_primary_container_dark</item>
        <!-- Secondary -->
        <item name="colorSecondary">@color/md_secondary_dark</item>
        <item name="colorOnSecondary">@color/md_on_secondary_dark</item>
        <item name="colorSecondaryContainer">@color/md_secondary_container_dark</item>
        <item name="colorOnSecondaryContainer">@color/md_on_secondary_container_dark</item>
        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/md_background_dark</item>
        <item name="colorOnBackground">@color/md_on_background_dark</item>
        <item name="colorSurface">@color/md_surface_dark</item>
        <item name="colorOnSurface">@color/md_on_surface_dark</item>
        <item name="colorSurfaceVariant">@color/md_surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/md_on_surface_variant_dark</item>
        <item name="colorOutline">@color/md_outline_dark</item>
        <item name="colorOutlineVariant">@color/md_outline_variant_dark</item>
        <!-- Inverse -->
        <item name="colorSurfaceInverse">@color/md_inverse_surface_dark</item>
        <item name="colorOnSurfaceInverse">@color/md_inverse_on_surface_dark</item>
        <item name="colorPrimaryInverse">@color/md_inverse_primary_dark</item>
        <!-- Error -->
        <item name="colorError">@color/md_error_dark</item>
        <item name="colorOnError">@color/md_on_error_dark</item>
        <item name="colorErrorContainer">@color/md_error_container_dark</item>
        <item name="colorOnErrorContainer">@color/md_on_error_container_dark</item>
        <!-- Status / nav bar -->
        <item name="android:statusBarColor" tools:targetApi="21">?attr/colorSurface</item>
    </style>
</resources>
