<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude key material from cloud backup (API 31+) -->
        <exclude domain="sharedpref" path="trusti_keys.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude key material from device-to-device transfer -->
        <exclude domain="sharedpref" path="trusti_keys.xml"/>
    </device-transfer>
</data-extraction-rules>
